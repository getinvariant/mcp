# ======================================
# BACKEND ENV VARS (set in Railway dashboard)
# ======================================
#
# MULTI-KEY SUPPORT: Any API key below accepts comma-separated values
# for automatic round-robin rotation with rate-limit failover.
#   Example: ANTHROPIC_API_KEY=sk-ant-key1,sk-ant-key2,sk-ant-key3
# A single key still works exactly as before.

# --- AI (free tiers) ---
ANTHROPIC_API_KEY=        # console.anthropic.com (paid) — supports multi-key
GOOGLE_GEMINI_API_KEY=    # aistudio.google.com — free, 1,500 req/day — supports multi-key
HUGGINGFACE_API_KEY=      # huggingface.co/settings/tokens — free — supports multi-key

# --- Finance (free tiers) ---
FINNHUB_API_KEY=          # finnhub.io — free, 60 req/min — supports multi-key
COINGECKO_API_KEY=        # coingecko.com/en/api — optional, boosts limit — supports multi-key

# --- Social Impact (free) ---
EVERY_ORG_API_KEY=        # partners.every.org — free — supports multi-key

# --- Environment (free) ---
OPENWEATHER_API_KEY=      # openweathermap.org/api — free, 60 req/min — supports multi-key

# --- Maps (free, no credit card) ---
GEOAPIFY_API_KEY=         # myprojects.geoapify.com — free, 3,000 req/day — supports multi-key

# --- Health (free, no key needed) ---
OPENFDA_API_KEY=          # open.fda.gov/apis/authentication — optional — supports multi-key
                          # NPPES NPI Registry — no key needed

# --- Creative (free) ---
UNSPLASH_ACCESS_KEY=      # unsplash.com/developers — free, 50 req/hr — supports multi-key
                          # Art Institute of Chicago — no key needed

# --- Admin ---
ADMIN_PASSWORD=           # Required: strong random value (e.g. `openssl rand -base64 32`). Never share in chat.

# --- Database (Supabase) ---
SUPABASE_URL=             # supabase.com project URL
SUPABASE_SERVICE_KEY=     # service role key — server-side only, never expose client-side

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Public URL (used for OAuth redirects, audit log links) ---
PUBLIC_URL=               # e.g. https://invariant-production.up.railway.app

# ======================================
# MCP CLIENT ENV VARS (participant config)
# ======================================
# PL_API_KEY=pl_their_key_here
# PL_BACKEND_URL=https://your-app.up.railway.app
