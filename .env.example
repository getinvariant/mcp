# ======================================
# BACKEND ENV VARS (set in Railway dashboard)
# ======================================

# --- AI (free tiers) ---
ANTHROPIC_API_KEY=        # console.anthropic.com (paid)
GOOGLE_GEMINI_API_KEY=    # aistudio.google.com — free, 1,500 req/day
HUGGINGFACE_API_KEY=      # huggingface.co/settings/tokens — free

# --- Finance (free tiers) ---
FINNHUB_API_KEY=          # finnhub.io — free, 60 req/min
COINGECKO_API_KEY=        # coingecko.com/en/api — optional, boosts limit; works without

# --- Social Impact (free) ---
EVERY_ORG_API_KEY=        # partners.every.org — free

# --- Environment (free) ---
OPENWEATHER_API_KEY=      # openweathermap.org/api — free, 60 req/min

# --- Maps (free, no credit card) ---
GEOAPIFY_API_KEY=         # myprojects.geoapify.com — free, 3,000 req/day

# --- Health (free, no key needed) ---
OPENFDA_API_KEY=          # open.fda.gov/apis/authentication — optional, boosts to 240 req/min

# --- Valid Procurement Labs keys (comma-separated) ---
PL_VALID_KEYS=pl_demo_key_2026

# ======================================
# MCP CLIENT ENV VARS (participant config)
# ======================================
# PL_API_KEY=pl_their_key_here
# PL_BACKEND_URL=https://your-app.up.railway.app
