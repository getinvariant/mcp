# ======================================
# BACKEND ENV VARS (set in Vercel dashboard)
# ======================================

# --- AI Providers ---
ANTHROPIC_API_KEY=           # anthropic.com
OPENAI_API_KEY=              # platform.openai.com
GOOGLE_GEMINI_API_KEY=       # aistudio.google.com
HUGGINGFACE_API_KEY=         # huggingface.co/settings/tokens

# --- Cloud Providers ---
AWS_ACCESS_KEY_ID=           # AWS IAM user with Comprehend access
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
GOOGLE_CLOUD_API_KEY=        # console.cloud.google.com (enable Translation API)

# --- Maps Providers ---
GOOGLE_MAPS_API_KEY=         # console.cloud.google.com (enable Maps, Places, Directions APIs)
# OpenStreetMap (Nominatim) — free, no key required

# --- Health / Finance / Impact / Environment ---
ALPHA_VANTAGE_API_KEY=       # alphavantage.co/support/#api-key
OPENWEATHER_API_KEY=         # openweathermap.org/api
EVERY_ORG_API_KEY=           # partners.every.org
OPENFDA_API_KEY=             # open.fda.gov/apis/authentication (optional, higher rate limits)

# --- Valid Procurement Labs keys (comma-separated) ---
# Generate with: node -e "console.log('pl_' + require('crypto').randomBytes(16).toString('hex'))"
PL_VALID_KEYS=pl_demo_key_2026

# ======================================
# MCP CLIENT ENV VARS (participant config)
# ======================================
# PL_API_KEY=pl_their_key_here
# PL_BACKEND_URL=https://your-app.vercel.app
